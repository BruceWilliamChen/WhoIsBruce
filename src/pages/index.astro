---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import Resume from '../components/Resume.astro';
import Photos from '../components/Photos.astro';
import Blog from '../components/Blog.astro';

const tabs = [
  { id: 'about',  label: 'About'  },
  { id: 'resume', label: 'Resume' },
  // { id: 'photos', label: 'Photos' },  // TODO: re-enable when Photos page is ready
  { id: 'blog',   label: 'Blog'   },
];
---

<Layout title="Bruce Chen">
  <div class="book-wrapper">
    <div class="book">

      <!-- Left: narrow strip -->
      <div class="left-strip">
        <button class="btn-cover" id="btn-cover">
          <img src="/WhoIsBruce/headshot.jpg" alt="Bruce Chen" class="headshot" />
        </button>
        <a class="btn-social btn-github" href="https://github.com/BruceWilliamChen" target="_blank" rel="noopener" aria-label="GitHub">
          <svg class="github-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </a>
        <a class="btn-social btn-linkedin" href="https://www.linkedin.com/in/bruceschen/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg class="social-icon" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>

      <!-- Right: top bar + content -->
      <div class="right-col">
        <nav class="top-bar">
          {tabs.map((t) => (
            <button class="tab-btn" data-section={t.id}>{t.label}</button>
          ))}
        </nav>

      <div class="pages">

          <div class="page active" id="page-cover">
            <div class="cover">
              <div class="term-window">
                <div class="term-chrome">
                  <span class="term-dot dot-r"></span>
                  <span class="term-dot dot-y"></span>
                  <span class="term-dot dot-g"></span>
                  <span class="term-title">bash — bchen@hal9000</span>
                </div>
                <div class="term-body">
                  <div class="term-line">
                    <span class="term-prompt">$ </span><span id="t-cmd"></span><span class="term-cursor" id="c-cmd">█</span>
                  </div>
                  <div class="term-gap"></div>
                  <div class="term-line term-out" id="line-1" style="visibility:hidden">
                    <span class="hal-tag">[HAL]:</span> <span id="t-1"></span><span class="term-cursor" id="c-1" style="visibility:hidden">█</span>
                  </div>
                  <div class="term-line term-out" id="line-2" style="visibility:hidden">
                    <span class="hal-tag">[HAL]:</span> <span id="t-2"></span><span class="term-cursor" id="c-2" style="visibility:hidden">█</span>
                  </div>
                  <div class="term-line term-out" id="line-3" style="visibility:hidden">
                    <span class="hal-tag">[HAL]:</span> <span id="t-3"></span><span class="term-cursor" id="c-3" style="visibility:hidden">█</span>
                  </div>
                  <div class="term-gap"></div>
                  <div class="term-line term-name-line" id="name-line" style="visibility:hidden">
                    <span id="t-name"></span><span class="term-cursor" id="c-name" style="visibility:hidden">█</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="page" id="page-about"><About /></div>
          <div class="page" id="page-resume"><Resume /></div>
          <div class="page" id="page-photos"><Photos /></div>
          <div class="page" id="page-blog"><Blog /></div>

      </div>

      </div><!-- end right-col -->

    </div>
  </div>
</Layout>

<style is:global>
  html, body {
    height: 100%;
    overflow: hidden;
    margin: 0;
  }

  .book-wrapper {
    width: 100%;
    height: 100vh;
    display: flex;
  }

  .book {
    display: grid;
    grid-template-columns: 110px 1fr;
    grid-template-rows: 1fr;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  /* ── Left strip ── */
  .left-strip {
    background: #1a1a1c;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 0.75rem;
    border-right: 1px solid rgba(255,255,255,0.06);
  }

  .btn-cover {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .headshot {
    width: 68px;
    height: 68px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 1.5px solid rgba(255,255,255,0.15);
    transform-origin: top center;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .btn-cover:hover .headshot {
    transform: scale(1.55);
    border-color: rgba(255,255,255,0.6);
    box-shadow: 0 0 18px rgba(255,255,255,0.12);
  }

  .btn-social {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1.25rem;
    width: 68px;
    height: 68px;
    border-radius: 50%;
    overflow: hidden;
    border: 1.5px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.75);
    transform-origin: top center;
    transition: transform 0.25s ease, color 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .btn-github { color: rgba(255,255,255,0.9); }
  .btn-linkedin { color: #0A66C2; }

  .btn-social:hover {
    transform: scale(1.55);
    border-color: rgba(255,255,255,0.6);
    box-shadow: 0 0 18px rgba(255,255,255,0.12);
  }

  .social-icon {
    width: 68px;
    height: 68px;
  }

  /* ── Right column ── */
  .right-col {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ── Top tab bar ── */
  .top-bar {
    background: #1a1a1c;
    border-bottom: 1px solid rgba(0,0,0,0.5);
    display: flex;
    align-items: flex-end;
    height: 52px;
    padding: 0;
    gap: 3px;
    flex-shrink: 0;
  }

  .tab-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-bottom: none;
    border-top: 2px solid transparent;
    border-radius: 6px 6px 0 0;
    color: rgba(255,255,255,0.38);
    font-family: 'Courier New', Courier, monospace;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: lowercase;
    padding: 0 1.8rem;
    height: 38px;
    cursor: pointer;
    transition: background 0.12s, color 0.12s, border-color 0.12s;
  }
  .tab-btn:hover {
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.9);
    border-color: rgba(255,255,255,0.18);
  }
  .tab-btn.active {
    background: #2e2e32;
    color: #3fb950;
    border-color: rgba(255,255,255,0.12);
    border-top-color: rgba(255,255,255,0.12);
    text-shadow: 0 0 8px rgba(63,185,80,0.6), 0 0 20px rgba(63,185,80,0.25);
  }

  /* ── Pages ── */
  .pages {
    flex: 1;
    overflow: hidden;
    background: #0d1117;
    position: relative;
  }

  .page {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    opacity: 0;
    transform: translateY(18px);
    pointer-events: none;
    transition: none;
  }

  .page.active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .page.exit {
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* ── Cover ── */
  .cover {
    width: 100%;
    height: 100%;
    background: radial-gradient(ellipse at center, #252528 0%, #1a1a1c 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Terminal window */
  .term-window {
    width: min(1170px, 90%);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 32px 80px rgba(0,0,0,0.7);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .term-chrome {
    background: #2a2a2e;
    padding: 0.65rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    border-bottom: 1px solid rgba(0,0,0,0.4);
  }

  .term-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot-r { background: #ff5f57; }
  .dot-y { background: #febc2e; }
  .dot-g { background: #28c840; }

  .term-title {
    flex: 1;
    text-align: center;
    font-family: system-ui, sans-serif;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.03em;
    margin-right: 52px; /* visually centers relative to dots */
  }

  .term-body {
    background: #0d1117;
    padding: 3.5rem 4rem 5rem;
    font-family: 'Courier New', Courier, monospace;
    min-height: 360px;
  }

  .term-line {
    line-height: 1.7;
  }

  .term-prompt {
    color: #3fb950;
    font-size: 1.5rem;
    font-weight: 700;
    user-select: none;
  }

  #t-cmd, #t-1, #t-2, #t-3 {
    color: #e6edf3;
    font-size: 1.5rem;
  }

  .hal-tag {
    color: #f87171;
    font-size: 1.5rem;
  }

  .term-gap {
    height: 0.75rem;
  }

  .term-name-line {
    margin-top: 0.5rem;
  }

  #t-name {
    font-size: clamp(3.3rem, 7.5vw, 4.8rem);
    font-weight: 700;
    color: #e6edf3;
  }

  .term-cursor {
    color: #3fb950;
    font-size: 1.5rem;
    animation: blink 0.75s step-end infinite;
  }

  #c-name {
    font-size: clamp(3.3rem, 7.5vw, 4.8rem);
    color: #e6edf3;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }


  /* ── Section content ── */
  .section-content {
    padding: 3rem;
  }

  .section-content h2 {
    font-size: 1.8rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: #111;
  }

  .section-content p {
    color: #555;
    line-height: 1.7;
  }

  /* Resume page — terminal fills full pane */
  #page-resume {
    padding: 0;
    overflow: hidden;
  }
</style>

<script>
  /* ── Typewriter ── */
  const sleep = (ms: number) => new Promise(r => setTimeout(r, ms));
  let twToken = 0;

  async function runTypewriter() {
    const token = ++twToken;

    const cmdEl    = document.getElementById('t-cmd')!;
    const cCmd     = document.getElementById('c-cmd')!;
    const line1    = document.getElementById('line-1')!;
    const t1       = document.getElementById('t-1')!;
    const c1       = document.getElementById('c-1')!;
    const line2    = document.getElementById('line-2')!;
    const t2       = document.getElementById('t-2')!;
    const c2       = document.getElementById('c-2')!;
    const line3    = document.getElementById('line-3')!;
    const t3       = document.getElementById('t-3')!;
    const c3       = document.getElementById('c-3')!;
    const nameLine = document.getElementById('name-line')!;
    const nameEl   = document.getElementById('t-name')!;
    const cName    = document.getElementById('c-name')!;

    // Reset
    cmdEl.textContent = '';
    t1.textContent = ''; t2.textContent = ''; t3.textContent = '';
    nameEl.textContent = '';
    cCmd.style.visibility = 'visible';
    line1.style.visibility = 'hidden';
    line2.style.visibility = 'hidden';
    line3.style.visibility = 'hidden';
    nameLine.style.visibility = 'hidden';
    c1.style.visibility = 'hidden';
    c2.style.visibility = 'hidden';
    c3.style.visibility = 'hidden';
    cName.style.visibility = 'hidden';
    cName.style.opacity = '1';
    cName.style.transition = 'none';

    const alive = () => twToken === token;

    const type = async (el: HTMLElement, text: string, speed = 70) => {
      for (const ch of text) {
        if (!alive()) return;
        el.textContent += ch;
        await sleep(speed + Math.random() * 45);
      }
    };
    const del = async (el: HTMLElement, count: number, speed = 85) => {
      for (let i = 0; i < count; i++) {
        if (!alive()) return;
        el.textContent = el.textContent!.slice(0, -1);
        await sleep(speed + Math.random() * 30);
      }
    };

    // Type command with a small typo
    await sleep(400);                                          if (!alive()) return;
    await type(cmdEl, 'hal9000 --identtify', 42);              if (!alive()) return;
    await sleep(200);                                          if (!alive()) return;
    await del(cmdEl, 4, 60);                                   if (!alive()) return;
    await type(cmdEl, 'ify user', 42);                         if (!alive()) return;
    await sleep(350);                                          if (!alive()) return;
    cCmd.style.visibility = 'hidden';

    // HAL line 1
    await sleep(250);                                          if (!alive()) return;
    line1.style.visibility = 'visible';
    c1.style.visibility = 'visible';
    await type(t1, 'Good morning.', 36);                       if (!alive()) return;
    await sleep(120);                                          if (!alive()) return;
    c1.style.visibility = 'hidden';

    // HAL line 2
    await sleep(220);                                          if (!alive()) return;
    line2.style.visibility = 'visible';
    c2.style.visibility = 'visible';
    await type(t2, 'Retrieving crew manifest...', 30);         if (!alive()) return;
    await sleep(120);                                          if (!alive()) return;
    c2.style.visibility = 'hidden';

    // HAL line 3
    await sleep(220);                                          if (!alive()) return;
    line3.style.visibility = 'visible';
    c3.style.visibility = 'visible';
    await type(t3, 'I think you should meet someone.', 30);    if (!alive()) return;
    await sleep(120);                                          if (!alive()) return;
    c3.style.visibility = 'hidden';

    // Name reveal
    await sleep(550);                                          if (!alive()) return;
    nameLine.style.visibility = 'visible';
    cName.style.visibility = 'visible';
    await type(nameEl, 'Bruce', 70);                           if (!alive()) return;
    await sleep(1000);                                         if (!alive()) return;
    cName.style.transition = 'opacity 0.6s ease';
    cName.style.opacity = '0';
  }

  runTypewriter();

  /* ── Tabs ── */
  const tabBtns = document.querySelectorAll<HTMLElement>('.tab-btn');
  let current = 'cover';
  let animating = false;

  document.getElementById('btn-cover')?.addEventListener('click', () => {
    transitionTo('cover');
    tabBtns.forEach(b => b.classList.remove('active'));
    runTypewriter();
  });

  function transitionTo(target: string) {
    if (target === current || animating) return;
    animating = true;

    const outEl = document.getElementById(`page-${current}`);
    const inEl  = document.getElementById(`page-${target}`);
    if (!outEl || !inEl) return;

    outEl.classList.add('exit');
    outEl.classList.remove('active');

    setTimeout(() => {
      outEl.classList.remove('exit');
      inEl.classList.add('active');
      current = target;
      setTimeout(() => { animating = false; }, 350);
    }, 200);
  }

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.section!;
      tabBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      transitionTo(target);
      if (target === 'resume') (window as any).runResumeIntro?.();
      if (target === 'about')  (window as any).runAboutIntro?.();
      if (target === 'blog')   (window as any).runBlogIntro?.();
    });
  });

  // Handle direct hash links (e.g. shared LinkedIn URLs)
  const initHash = window.location.hash;
  if (initHash.startsWith('#blog')) {
    tabBtns.forEach(b => b.classList.remove('active'));
    document.querySelector<HTMLElement>('[data-section="blog"]')?.classList.add('active');
    document.getElementById('page-cover')?.classList.remove('active');
    document.getElementById('page-blog')?.classList.add('active');
    current = 'blog';
    setTimeout(() => {
      if (initHash.startsWith('#blog/')) (window as any).checkBlogHash?.();
      else (window as any).runBlogIntro?.();
    }, 50);
  }
</script>
